{
  "name": "@magupe/orbiting-avatar",
  "version": "1.0.0",
  "description": "Avatar component with orbiting tech skill icons — like a planetary system around your profile picture",
  "type": "module",
  "license": "MIT",
  "author": "MagupeDev",
  "keywords": [
    "react",
    "avatar",
    "orbiting",
    "animation",
    "skills",
    "framer-motion",
    "portfolio"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Magupe09/GalleryReact",
    "directory": "packages/orbiting-avatar"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/orbiting-avatar.cjs",
  "module": "./dist/orbiting-avatar.js",
